  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSystem
  textDisplay: {fileID: 188403403}
  sentences:
  - Alright, I'm at the terminal. The signal is a mess, but I think I can see the
    data nodes.
  - It looks like a standard frequency bypass. I just need to link these matching
    colors to bridge the circuit.
  - Wait... the grid is more unstable than the briefing said. If I cross the lines,
    the connection will drop.
  - Keep an eye on the monitor while I try to sync these up. If the screen flashes
    red, let me know.
  typingSpeed: 0.05
  playButton: {fileID: 1754827769}
  gameSceneName: LEVEL1
